{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,

    /* typy pro Node, Vite a Netlify Functions */
    "types": ["node", "vite/client", "@netlify/functions"]
  },
  "include": [
    "vite.config.ts",
    "netlify/functions/**/*.ts",
    "src/types/env.d.ts"
  ]
}
